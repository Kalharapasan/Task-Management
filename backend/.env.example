# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Cookie SameSite mode for the refresh-token cookie.
# 'lax'  -> local dev / Docker (frontend+backend share the same site, different ports)
# 'none' -> Vercel (frontend and backend live on two different domains; requires HTTPS)
COOKIE_SAME_SITE=lax

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=task_management
DB_USER=root
DB_PASSWORD=

# JWT - access token (short-lived, sent in the Authorization header)
JWT_SECRET=replace_this_with_a_long_random_secret_string
ACCESS_TOKEN_EXPIRES_IN=15m

# JWT - refresh token (long-lived, stored as an httpOnly cookie)
JWT_REFRESH_SECRET=replace_this_with_a_different_long_random_secret_string
REFRESH_TOKEN_EXPIRES_IN=7d

# Default seeded user (matches assessment requirements)
DEFAULT_USER_NAME=Admin User
DEFAULT_USER_EMAIL=admin@test.com
DEFAULT_USER_PASSWORD=123456
